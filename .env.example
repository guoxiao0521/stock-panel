# better-auth 基础配置
# BETTER_AUTH_SECRET 生成示例：openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Supabase Postgres（服务端 secret，不要放入 public runtime config 或前端代码）
# 推荐使用 Supabase Transaction pooler，并带 search_path：
# postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?options=-c%20search_path%3Dstock_panel,public
DATABASE_URL=

# 可选：migration/admin 使用 direct connection
DATABASE_DIRECT_URL=

# Google OAuth 凭据
# 在 Google Cloud Console > APIs & Services > Credentials 创建"OAuth 2.0 客户端 ID"
# 应用类型：Web 应用
# 已获授权的重定向 URI（开发）：http://localhost:3000/api/auth/callback/google
# 已获授权的重定向 URI（生产）：https://<你的域名>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
